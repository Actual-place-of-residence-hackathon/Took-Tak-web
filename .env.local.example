NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

ADMIN_PASSCODE=

# 백엔드(Took-Tak-back) 연동 — 서버(Route Handler) 전용, 브라우저에 노출되지 않음
# 로컬 개발: http://localhost:4000
# 배포 환경: 프론트 EC2와 같은 VPC 안의 백엔드 사설 IP (예: http://10.28.3.146:4000)
BACKEND_INTERNAL_URL=http://localhost:4000
# 백엔드에 자동 등록/로그인할 고정 관리자 계정. 값은 임의로 정하되 아래 코드와
# 세트로 취급합니다.
BACKEND_ADMIN_ID=admin
# 백엔드 .env 의 ADMIN_SIGNUP_CODE 와 반드시 동일한 값이어야 합니다.
BACKEND_ADMIN_SIGNUP_CODE=
